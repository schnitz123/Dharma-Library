{%if settings.dgHomeLink === true%}
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" style="text-decoration: none;">
                {% if meta.siteLogoPath %}
                    <img class="site-logo" src="{{meta.siteLogoPath}}" alt="{{meta.siteName}}">
                {% else %}
                    <h1 style="margin: 15px !important;">{{meta.siteName}}</h1>
                {% endif %}
            </a>
            <ul class="nav-links">
                <li><a href="/website/about-me/">About me</a></li>
                <li><a href="/website/written-translations/">Written translations</a></li>
                <li><a href="/website/offerings/">Make an offering</a></li>
                <li>{% if settings.dgEnableSearch === true%}
                    {% include "components/searchButton.njk" %}
                    {%endif%}</li>
            </ul>
        
            
        </div>   
    </nav>

    <nav class="navbar-mobile">
        <div class="navbar-inner">
            <a href="/" style="text-decoration: none;">
                <h3 style="margin: 10px !important;">{{meta.siteName}}</h3>
            </a>
            </div>
    </nav>

{%else%}
    <div class="empty-navbar">
        {% if settings.dgEnableSearch === true%}
            {% include "components/searchButton.njk" %}
        {%endif%}
    </div>
{%endif%}
